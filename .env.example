# Database
DATABASE_URL="file:./dev.db"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-here-change-in-production"

# AI Provider (OpenAI-compatible)
AI_API_KEY="your-ai-api-key"
AI_API_BASE_URL="https://api.openai.com/v1"
AI_MODEL="gpt-4o"
AI_PROVIDER_ID="openai"
AI_TEMPERATURE="0.7"
AI_MAX_TOKENS="4000"

# Hermes Agent Framework Configuration
HERMES_LEARNING_ENABLED="true"
HERMES_MEMORY_ENABLED="true"
HERMES_SKILLS_ENABLED="true"
HERMES_MAX_MEMORY_SIZE="1000"
HERMES_SKILL_TIMEOUT="30000"

# Optional: Advanced AI Configuration
# AI_FALLBACK_MODEL="gpt-3.5-turbo"
# AI_RETRY_ATTEMPTS="3"
# AI_REQUEST_TIMEOUT="60000"

# ============================================================================
# Mining Feature - Tempo Network Configuration
# ============================================================================

# Tempo Network
# Testnet (recommended for development)
TEMPO_RPC_URL="https://rpc.moderato.tempo.xyz"
TEMPO_CHAIN_ID="42431"

# Mainnet (for production only)
# TEMPO_RPC_URL="https://rpc.tempo.xyz"
# TEMPO_CHAIN_ID="4217"

# REAGENT Token (deployed via scripts/deploy-reagent-token.ts)
REAGENT_TOKEN_ADDRESS=""  # Will be filled after deployment

# Platform Admin Wallet (for token deployment and role management)
PLATFORM_ADMIN_PRIVATE_KEY=""  # Private key with 0x prefix
PLATFORM_ADMIN_ADDRESS=""      # Optional: for verification

# Platform Wallet (receives ISSUER_ROLE, used for minting)
PLATFORM_WALLET_ADDRESS=""
PLATFORM_WALLET_PRIVATE_KEY=""  # Private key with 0x prefix

# Quote Token (USD-denominated TIP-20 token for DEX pairing)
QUOTE_TOKEN_ADDRESS=""  # Address of USD stablecoin on Tempo

# Wallet Encryption (for storing user private keys)
WALLET_ENCRYPTION_KEY=""  # Strong secret key for AES-256 encryption

# Mining Configuration
INSCRIPTION_RATE_LIMIT="10"        # Max inscriptions per hour per user
INSCRIPTION_RATE_WINDOW="3600"     # Rate limit window in seconds
GAS_ESTIMATE_BUFFER="1.2"          # 20% buffer for gas estimation
GAS_PRICE_CACHE_TTL="60"           # Gas price cache TTL in seconds

# Trading Configuration
PLATFORM_FEE_PERCENTAGE="1"        # 1% platform fee on trades
MAX_ORDERS_PER_USER="50"           # Max active orders per user

# Optional: Testing
# TEST_MINT_ADDRESS=""  # Address to use for mint testing

# ============================================================================
# Privy Authentication (Web3 + Social Login)
# ============================================================================
# Get your App ID from https://dashboard.privy.io
NEXT_PUBLIC_PRIVY_APP_ID="your-privy-app-id"
PRIVY_APP_SECRET="your-privy-app-secret"
