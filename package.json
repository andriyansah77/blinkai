{
  "name": "reagent",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev -H 0.0.0.0",
    "build": "next build",
    "start": "next start -H 0.0.0.0",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:ui": "vitest --ui",
    "db:push": "prisma db push",
    "db:studio": "prisma studio",
    "postinstall": "prisma generate",
    "setup:hermes": "node scripts/setup-hermes.js",
    "test:hermes": "node scripts/test-hermes.js",
    "setup": "npm run db:push && npm run setup:hermes",
    "push:github": "powershell -ExecutionPolicy Bypass -File scripts/push-to-github-simple.ps1",
    "push:github:linux": "bash scripts/push-to-github.sh",
    "deploy:vps": "powershell -ExecutionPolicy Bypass -File scripts/deploy-vps-simple.ps1",
    "fix:vps": "powershell -ExecutionPolicy Bypass -File scripts/fix-vps-deployment.ps1",
    "update:vps": "powershell -ExecutionPolicy Bypass -File scripts/update-vps-from-github.ps1",
    "deploy:help": "echo 'Deploy commands:' && echo '  npm run push:github -- -Token YOUR_TOKEN' && echo '  npm run deploy:vps' && echo '  npm run deploy:github -- -r user/repo -u USER -h HOST'",
    "deploy:github": "bash scripts/setup-github-deploy.sh",
    "deploy:linux": "bash scripts/deploy-to-vps.sh",
    "deploy:windows": "powershell -ExecutionPolicy Bypass -File scripts/deploy-to-vps.ps1",
    "update:github": "bash scripts/update-from-github.sh",
    "reagent:deploy": "npx ts-node --project scripts/tsconfig.json scripts/deploy-reagent-token.ts",
    "reagent:verify": "npx ts-node --project scripts/tsconfig.json scripts/verify-reagent-roles.ts",
    "reagent:test": "npx ts-node --project scripts/tsconfig.json scripts/test-reagent-mint.ts",
    "reagent:all": "npm run reagent:deploy && npm run reagent:verify && npm run reagent:test",
    "tempo:setup": "powershell -ExecutionPolicy Bypass -File scripts/setup-tempo-wallet.ps1",
    "tempo:setup:linux": "bash scripts/setup-tempo-wallet.sh",
    "reagent:deploy:tempo": "npx ts-node --project scripts/tsconfig.json scripts/deploy-with-tempo-cli.ts",
    "reagent:deploy:production": "npx ts-node --project scripts/tsconfig.json scripts/deploy-production.ts",
    "reagent:deploy:direct": "npx ts-node --project scripts/tsconfig.json scripts/deploy-direct.ts",
    "reagent:deploy:manual": "npx ts-node --project scripts/tsconfig.json scripts/deploy-manual.ts"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.7.2",
    "@farcaster/mini-app-solana": "^2.0.0",
    "@farcaster/miniapp-sdk": "^0.3.0",
    "@metamask/connect-evm": "^0.9.1",
    "@monaco-editor/react": "^4.6.0",
    "@prisma/client": "^5.22.0",
    "@privy-io/node": "^0.14.0",
    "@privy-io/react-auth": "^3.21.2",
    "@privy-io/wagmi": "^4.0.5",
    "@radix-ui/react-avatar": "^1.1.1",
    "@radix-ui/react-dialog": "^1.1.2",
    "@radix-ui/react-dropdown-menu": "^2.1.2",
    "@radix-ui/react-label": "^2.1.0",
    "@radix-ui/react-scroll-area": "^1.2.1",
    "@radix-ui/react-select": "^2.1.2",
    "@radix-ui/react-separator": "^1.1.0",
    "@radix-ui/react-slot": "^1.1.0",
    "@radix-ui/react-tabs": "^1.1.1",
    "@radix-ui/react-toast": "^1.2.2",
    "@radix-ui/react-tooltip": "^1.1.4",
    "@solana/wallet-adapter-react": "^0.15.39",
    "@tanstack/query-core": "^5.99.0",
    "@tanstack/react-query": "^5.99.0",
    "axios": "^1.6.0",
    "bcryptjs": "^2.4.3",
    "child_process": "^1.0.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "decimal.js": "^10.6.0",
    "ethers": "^6.16.0",
    "framer-motion": "^11.15.0",
    "fs-extra": "^11.2.0",
    "highlight.js": "^11.9.0",
    "jszip": "^3.10.1",
    "lucide-react": "^0.468.0",
    "marked": "^12.0.0",
    "next": "14.2.18",
    "next-auth": "^4.24.10",
    "next-themes": "^0.4.4",
    "node-cron": "^3.0.3",
    "node-pty": "^1.1.0",
    "pdf-parse": "^2.4.5",
    "porto": "^0.2.37",
    "prisma": "^5.22.0",
    "react": "^18",
    "react-dom": "^18",
    "react-hot-toast": "^2.4.1",
    "react-markdown": "^10.1.0",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^2.5.5",
    "tailwindcss-animate": "^1.0.7",
    "uuid": "^9.0.1",
    "viem": "^2.47.4",
    "wagmi": "^3.6.1",
    "ws": "^8.18.0",
    "yaml": "^2.3.4"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@testing-library/user-event": "^14.5.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/fs-extra": "^11.0.0",
    "@types/marked": "^5.0.0",
    "@types/node": "^20",
    "@types/node-cron": "^3.0.11",
    "@types/pdf-parse": "^1.1.5",
    "@types/react": "^18",
    "@types/react-dom": "^18",
    "@types/uuid": "^9.0.7",
    "@types/ws": "^8.5.10",
    "@vitejs/plugin-react": "^4.2.1",
    "autoprefixer": "^10.0.1",
    "eslint": "^8",
    "eslint-config-next": "14.2.18",
    "jsdom": "^23.0.1",
    "postcss": "^8",
    "tailwindcss": "^3.4.1",
    "ts-node": "^10.9.2",
    "typescript": "^5",
    "vitest": "^1.0.4"
  }
}
