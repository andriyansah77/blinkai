generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── User ─────────────────────────────────────────────────────────────────────
model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  role      String   @default("user") // "user" | "admin"
  createdAt DateTime @default(now())

  // Relations
  agents       Agent[]
  creditLedger CreditLedger[]
  apiKeyConfig ApiKeyConfig?
  hermesAgents HermesAgent[]
  hermesSessions HermesSession[]
  hermesMemories HermesMemory[]
  feedback     Feedback[]
  
  // Mining feature relations
  wallet              Wallet?
  usdBalance          UsdBalance?
  inscriptions        Inscription[]
  inscriptionSchedules InscriptionSchedule[]
  tradeOrders         TradeOrder[]
  buyTrades           Trade[] @relation("BuyerTrades")
  sellTrades          Trade[] @relation("SellerTrades")
}

// ─── API Key Config (per user) ─────────────────────────────────────────────────
// BYOK = user bawa key sendiri
// platform = pakai credit dari platform (default)
model ApiKeyConfig {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  mode       String   @default("platform") // "platform" | "byok"

  // BYOK fields (encrypted at app level)
  byokApiKey  String?
  byokBaseUrl String?
  byokModel   String?

  // Mining API Key for AI agent access
  miningApiKey String?

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

// ─── Credit Ledger ─────────────────────────────────────────────────────────────
model CreditLedger {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  amount    Int      // positive = topup, negative = usage
  reason    String   // "signup_bonus" | "usage" | "topup" | "admin_grant"
  meta      String   @default("{}") // JSON: agentId, tokens, etc.

  createdAt DateTime @default(now())
}

// ─── Agent ────────────────────────────────────────────────────────────────────
model Agent {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name        String
  slug        String   @unique // URL-friendly: used in /agent/:slug
  description String?
  avatar      String?  // emoji or URL

  // Hermes config
  systemPrompt String  @default("")
  model        String  @default("") // empty = use platform default
  temperature  Float   @default(0.7)
  maxTokens    Int     @default(2048)

  // Agent template
  template     String  @default("assistant") // "assistant" | "support" | "sales" | "custom"

  // Status
  status       String  @default("active") // "active" | "paused" | "deleted"
  isPublic     Boolean @default(false) // public shareable link

  // Stats (denormalized for speed)
  totalMessages Int    @default(0)
  totalTokens   Int    @default(0)

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sessions    AgentSession[]
}

// ─── Agent Session (conversation) ────────────────────────────────────────────
model AgentSession {
  id        String   @id @default(cuid())
  agentId   String
  agent     Agent    @relation(fields: [agentId], references: [id], onDelete: Cascade)

  // Anonymous visitor or identified user
  visitorId String?  // fingerprint/cookie for public agents
  title     String?  // auto-generated from first message

  messages  String   @default("[]") // JSON array of {role, content, ts}
  tokenUsed Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// ─── Hermes Agent Framework Models ────────────────────────────────────────────

// ─── Hermes Agent ─────────────────────────────────────────────────────────────
model HermesAgent {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  name          String
  description   String   @default("")
  model         String   @default("gpt-4o")
  provider      String   @default("openai")
  systemPrompt  String   @default("")
  temperature   Float    @default(0.7)
  maxTokens     Int      @default(4000)
  tools         String   @default("[]") // JSON array of tool names
  
  // Learning capabilities
  memoryEnabled    Boolean @default(true)
  learningEnabled  Boolean @default(true)
  
  // Status
  status        String   @default("active") // "active" | "paused" | "deleted"
  
  // Stats
  totalSessions    Int @default(0)
  totalMessages    Int @default(0)
  totalSkillsUsed  Int @default(0)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relations
  skills        HermesSkill[]
  sessions      HermesSession[]
  memories      HermesMemory[]
}

// ─── Hermes Skill ─────────────────────────────────────────────────────────────
model HermesSkill {
  id          String      @id @default(cuid())
  agentId     String
  agent       HermesAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)

  name        String
  description String      @default("")
  code        String      // JavaScript code for the skill
  category    String      @default("general")
  tags        String      @default("[]") // JSON array of tags
  
  // Usage stats
  usage       Int         @default(0)
  rating      Float       @default(0.0)
  
  // Status
  status      String      @default("active") // "active" | "disabled" | "error"
  
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@unique([agentId, name])
}

// ─── Hermes Session ───────────────────────────────────────────────────────────
model HermesSession {
  id        String      @id @default(cuid())
  agentId   String
  agent     HermesAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  title     String      @default("New Session")
  messages  String      @default("[]") // JSON array of messages
  context   String      @default("{}") // JSON object for session context
  
  // Stats
  messageCount Int       @default(0)
  tokenUsed    Int       @default(0)
  skillsUsed   String    @default("[]") // JSON array of skill IDs used
  
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
}

// ─── Hermes Memory ────────────────────────────────────────────────────────────
model HermesMemory {
  id          String      @id @default(cuid())
  agentId     String
  agent       HermesAgent @relation(fields: [agentId], references: [id], onDelete: Cascade)
  userId      String
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  type        String      // "conversation" | "skill" | "user_preference" | "context"
  content     String      // The memory content
  metadata    String      @default("{}") // JSON object for additional data
  importance  Float       @default(0.5) // 0.0 to 1.0
  
  // Vector embedding (for future semantic search)
  embedding   String?     // JSON array of floats
  
  createdAt   DateTime    @default(now())
  lastAccessed DateTime   @default(now())

  @@index([agentId, type])
  @@index([userId, importance])
}

// ─── Feedback ─────────────────────────────────────────────────────────────────
model Feedback {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  type      String   // "chat" | "feature" | "bug" | "general"
  rating    Int      // 1-5 stars
  message   String?  // Optional feedback message
  context   String?  // JSON object with additional context (agentId, sessionId, etc.)

  createdAt DateTime @default(now())

  @@index([userId, type])
}

// ─── Mining Feature Models ────────────────────────────────────────────────────

// ─── Wallet ───────────────────────────────────────────────────────────────────
model Wallet {
  id                   String   @id @default(cuid())
  userId               String   @unique
  user                 User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  address              String   @unique
  encryptedPrivateKey  String   // AES-256 encrypted
  keyIv                String   // Initialization vector for encryption
  
  // Balances (cached from blockchain)
  reagentBalance       String   @default("0") // BigInt as string
  pathusdBalance       String   @default("0") // BigInt as string
  lastBalanceUpdate    DateTime @default(now())
  
  // Metadata
  network              String   @default("tempo")
  derivationPath       String?  // HD wallet path
  imported             Boolean  @default(false)
  
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt
  
  // Relations
  inscriptions         Inscription[]
  usdBalance           UsdBalance?
  tradeOrders          TradeOrder[]
  
  @@index([userId])
  @@index([address])
}

// ─── USD Balance ──────────────────────────────────────────────────────────────
model UsdBalance {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  walletId      String   @unique
  wallet        Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  
  balance       String   @default("0") // Decimal as string (e.g., "100.50")
  lockedBalance String   @default("0") // Locked in trades
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  
  // Relations
  transactions  UsdTransaction[]
  
  @@index([userId])
}

// ─── USD Transaction ──────────────────────────────────────────────────────────
model UsdTransaction {
  id            String     @id @default(cuid())
  balanceId     String
  balance       UsdBalance @relation(fields: [balanceId], references: [id], onDelete: Cascade)
  
  // Transaction details
  type          String     // "deposit" | "withdrawal" | "inscription_fee" | "gas_fee" | "trade" | "refund"
  amount        String     // Decimal as string (positive or negative)
  balanceBefore String
  balanceAfter  String
  
  // Reference
  referenceType String?    // "inscription" | "trade" | "manual"
  referenceId   String?    // ID of related inscription/trade
  
  // Metadata
  description   String?
  adminId       String?    // For manual deposits/adjustments
  
  createdAt     DateTime   @default(now())
  
  @@index([balanceId, createdAt])
}

// ─── Inscription ──────────────────────────────────────────────────────────────
model Inscription {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  walletId        String
  wallet          Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  
  // Inscription details
  type            String   // "auto" | "manual" | "scheduled"
  status          String   // "pending" | "submitted" | "confirmed" | "failed"
  
  // Amounts
  inscriptionFee  String   // 0.5 or 1.0 PATHUSD
  gasEstimate     String
  gasFee          String?  // Actual gas paid (renamed from gasActual)
  tokensEarned    String   @default("10000") // REAGENT tokens (renamed from tokensReceived)
  
  // Blockchain data
  txHash          String?  @unique
  blockNumber     Int?     // Changed to Int for consistency
  confirmations   Int      @default(0)
  
  // Error handling
  errorMessage    String?
  refunded        Boolean  @default(false)
  retryCount      Int      @default(0)
  
  // Schedule reference
  scheduleId      String?
  schedule        InscriptionSchedule? @relation(fields: [scheduleId], references: [id])
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  confirmedAt     DateTime?
  
  @@index([userId, status])
  @@index([walletId, createdAt])
}

// ─── Inscription Schedule ─────────────────────────────────────────────────────
model InscriptionSchedule {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Schedule configuration
  frequency       String   // "hourly" | "daily" | "weekly" | "monthly" | "custom"
  cronExpression  String   // Cron format
  enabled         Boolean  @default(true) // Active or paused
  maxExecutions   Int?     // Optional limit on total executions
  executionCount  Int      @default(0) // Number of times executed
  
  // Status tracking
  lastExecution   DateTime?
  nextExecution   DateTime?
  lastExecutionStatus String? // "success" | "failed"
  pauseReason     String?  // Reason for pause (e.g., "Insufficient balance")
  notifyOnPause   Boolean  @default(true) // Send notification when paused
  
  // Hermes cron job reference
  hermesCronId    String?  @unique
  
  // Timestamps
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  
  // Relations
  inscriptions    Inscription[]
  
  @@index([userId, enabled])
}

// ─── Trade Order ──────────────────────────────────────────────────────────────
model TradeOrder {
  id              String   @id @default(cuid())
  userId          String
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  walletId        String
  wallet          Wallet   @relation(fields: [walletId], references: [id], onDelete: Cascade)
  
  // Order details
  type            String   // "buy" | "sell"
  status          String   // "open" | "partial" | "filled" | "cancelled"
  
  // Amounts
  tokenAmount     String   // REAGENT amount
  pricePerToken   String   // Price in PATHUSD
  totalValue      String   // Total USD value
  filledAmount    String   @default("0")
  
  // Escrow
  lockedAmount    String   // Tokens (sell) or USD (buy) locked
  
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
  expiresAt       DateTime?
  
  // Relations
  buyTrades       Trade[] @relation("BuyOrderTrades")
  sellTrades      Trade[] @relation("SellOrderTrades")
  
  @@index([type, status, pricePerToken])
  @@index([userId, status])
}

// ─── Trade ────────────────────────────────────────────────────────────────────
model Trade {
  id              String     @id @default(cuid())
  buyOrderId      String
  buyOrder        TradeOrder @relation("BuyOrderTrades", fields: [buyOrderId], references: [id])
  sellOrderId     String
  sellOrder       TradeOrder @relation("SellOrderTrades", fields: [sellOrderId], references: [id])
  
  // Trade details
  tokenAmount     String     // REAGENT traded
  pricePerToken   String     // Execution price
  totalValue      String     // Total USD value
  platformFee     String     // 1% fee
  
  // Participants
  buyerId         String
  buyer           User       @relation("BuyerTrades", fields: [buyerId], references: [id])
  sellerId        String
  seller          User       @relation("SellerTrades", fields: [sellerId], references: [id])
  
  executedAt      DateTime   @default(now())
  
  @@index([buyerId, executedAt])
  @@index([sellerId, executedAt])
}
